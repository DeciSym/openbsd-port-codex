+#[cfg(test)]
+mod tests {
+    use super::*;
+    use codex_protocol::permissions::FileSystemAccessMode;
+    use codex_protocol::permissions::FileSystemPath;
+    use codex_protocol::permissions::FileSystemSandboxEntry;
+    use std::fs;
+    use std::os::unix::process::CommandExt;
+    use std::process::Command;
+    use tempfile::TempDir;
+
+    #[test]
+    fn workspace_write_plan_maps_read_only_subpaths_to_narrower_unveils() {
+        let temp_dir = TempDir::new().expect("temp dir");
+        let root = AbsolutePathBuf::from_absolute_path(temp_dir.path()).expect("absolute root");
+        let git_dir = root.join(".git");
+        fs::create_dir(git_dir.as_path()).expect("create .git");
+
+        let policy = FileSystemSandboxPolicy::restricted(vec![
+            FileSystemSandboxEntry {
+                path: FileSystemPath::Path { path: root.clone() },
+                access: FileSystemAccessMode::Write,
+            },
+            FileSystemSandboxEntry {
+                path: FileSystemPath::Path {
+                    path: git_dir.clone(),
+                },
+                access: FileSystemAccessMode::Read,
+            },
+        ]);
+
+        let plan = build_plan(&policy, NetworkSandboxPolicy::Restricted, root.as_path());
+
+        assert!(
+            plan.unveil_rules
+                .iter()
+                .any(|rule| rule.path == root.as_path() && rule.permissions == "rwcx")
+        );
+        assert!(
+            plan.unveil_rules
+                .iter()
+                .any(|rule| rule.path == git_dir.as_path() && rule.permissions == "rx")
+        );
+        assert!(!plan.promises.contains(" inet"));
+        assert!(plan.promises.contains(" wpath"));
+    }
+
+    #[test]
+    fn enabled_network_adds_network_promises() {
+        let policy = FileSystemSandboxPolicy::unrestricted();
+        let cwd = AbsolutePathBuf::current_dir().expect("cwd");
+
+        let plan = build_plan(&policy, NetworkSandboxPolicy::Enabled, cwd.as_path());
+
+        assert!(plan.unveil_rules.is_empty());
+        assert!(plan.promises.contains(" inet"));
+        assert!(plan.promises.contains(" dns"));
+        assert!(plan.promises.contains(" unix"));
+    }
+
+    #[test]
+    fn apply_child_sandbox_prevents_writes_to_read_only_carveouts() {
+        let temp_dir = TempDir::new().expect("temp dir");
+        let root = AbsolutePathBuf::from_absolute_path(temp_dir.path()).expect("absolute root");
+        let git_dir = root.join(".git");
+        fs::create_dir(git_dir.as_path()).expect("create .git");
+
+        let policy = FileSystemSandboxPolicy::restricted(vec![
+            FileSystemSandboxEntry {
+                path: FileSystemPath::Special {
+                    value: codex_protocol::permissions::FileSystemSpecialPath::Root,
+                },
+                access: FileSystemAccessMode::Read,
+            },
+            FileSystemSandboxEntry {
+                path: FileSystemPath::Path { path: root.clone() },
+                access: FileSystemAccessMode::Write,
+            },
+            FileSystemSandboxEntry {
+                path: FileSystemPath::Path { path: git_dir },
+                access: FileSystemAccessMode::Read,
+            },
+        ]);
+        let profile = OpenBsdSandboxProfile::new(&policy, NetworkSandboxPolicy::Restricted, &root)
+            .expect("profile");
+
+        let mut command = Command::new("/bin/sh");
+        command
+            .arg("-c")
+            .arg("echo ok > allowed && echo denied > .git/blocked")
+            .current_dir(root.as_path());
+        unsafe {
+            command.pre_exec(move || apply_child_sandbox(&profile));
+        }
+
+        let output = command.output().expect("spawn shell");
+        assert!(!output.status.success());
+        assert_eq!(
+            fs::read_to_string(root.join("allowed").as_path()).expect("allowed write"),
+            "ok\n"
+        );
+        assert!(!root.join(".git/blocked").as_path().exists());
+    }
+}
